PORT=5000
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# ==========================================
# API BASE URL (production)
# ==========================================
# Full base URL for API endpoints (including reverse proxy path)
# If not set, defaults to http://localhost:PORT/api
# API_BASE_URL=https://your-domain.example/api

# ==========================================
# DATABASE CONFIGURATION (MySQL / MariaDB)
# ==========================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=CHANGE_ME
DB_NAME=eureka

# ==========================================
# EGI Check-in Configuration
# ==========================================
EGI_CLIENT_ID=YOUR_EGI_CLIENT_ID
EGI_CLIENT_SECRET=YOUR_EGI_CLIENT_SECRET
EGI_REDIRECT_URI=http://localhost:5173/

# ==========================================
# TRELLIS Configuration (AI 3D Builder)
